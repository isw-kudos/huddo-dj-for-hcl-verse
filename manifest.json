{
  "manifest_version": 3,
  "name": "Huddo DJ for HCL Verse",
  "version": "1.0.0",
  "description": "Plays music that matches your HCL Verse inbox mood — Spotify, Apple Music, or YouTube Music.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://*/*",
    "https://accounts.spotify.com/*",
    "https://api.spotify.com/*",
    "https://music.apple.com/*",
    "https://music.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle-panel": {
      "suggested_key": { "default": "Alt+D" },
      "description": "Toggle the Huddo DJ for HCL Verse widget"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "huddo-email-dj@huddo.com",
      "strict_min_version": "128.0"
    }
  }
}
